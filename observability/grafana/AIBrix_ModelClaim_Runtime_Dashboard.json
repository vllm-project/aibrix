    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Worst-case warm-pool policy validity across the selected namespace(s): Invalid if any pool Deployment's `pool.aibrix.ai/policy` annotation is malformed, no data when none is set. Not filtered by $pool/$pod/$model (metric is keyed by namespace/deployment). When Invalid, the `aibrix_modelclaim_pool_policy_valid == 0` series names the offending Deployment — see the Events / logs cheat sheet to inspect it.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "index": 0,
                  "text": "Invalid"
                },
                "1": {
                  "index": 1,
                  "text": "Valid"
                }
              },
              "type": "value"
            }
          ],
          "noValue": "No policy set",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
