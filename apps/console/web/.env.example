# Console feature flags (build-time, consumed by src/config/features.ts).
#
# Copy to `.env.local` to override locally, or pass inline at build time.
# Unset => defaults to ON in `vite dev`, OFF in production builds.
# Accepted values: true / 1 / false / 0

# Gate the online Deployments UI (off => "Coming Soon" placeholder).
VITE_ENABLE_DEPLOYMENTS=false

# Gate the Playground UI (off => "Coming Soon" placeholder).
VITE_ENABLE_PLAYGROUND=false
