AUTH_MODE=dev
DEV_MODE=true

# Console backend
GRPC_ADDR=:50060
HTTP_ADDR=:8080
STORE_URI=sqlite:/tmp/aibrix-console.db

# Frontend static assets, optional when running frontend separately
# STATIC_FILES_DIR=/Users/bytedance/code/aibrix/apps/console/web/build

# Kubernetes driver configuration
K8S_KUBECONFIG=$HOME/.kube/config
K8S_CONTEXT=kind-aibrix
K8S_NAMESPACE=aibrix-console
K8S_SERVICE_TYPE=NodePort
K8S_CONTAINER_PORT=8000
K8S_SERVICE_PORT=8000
K8S_HPA_TARGET_CPU_UTILIZATION=80
