AUTH_MODE=dev
DEV_MODE=true

# Console backend
GRPC_ADDR=:50060
HTTP_ADDR=:8080
STORE_URI=sqlite:/tmp/aibrix-console.db

# Frontend static assets, optional when running frontend separately
# STATIC_FILES_DIR=./web/build

# Kubernetes deployment implementation
KUBERNETES_KUBECONFIG=$HOME/.kube/config
KUBERNETES_CONTEXT=kind-aibrix
KUBERNETES_NAMESPACE=aibrix-console
KUBERNETES_SERVICE_TYPE=NodePort
KUBERNETES_CONTAINER_PORT=8000
KUBERNETES_SERVICE_PORT=8000
KUBERNETES_CPU_REQUEST=1
KUBERNETES_HPA_TARGET_CPU_UTILIZATION=80
